msgstr "Nouveau paiement en attente : {transaction_type}"

#: subscribers/views.py:52
#, python-brace-format
msgid ""
"A new offline bank transfer request has been submitted.\n"
"\n"
"Client: {client_email}\n"
"Type: {transaction_type}\n"
"Amount: {total} TND\n"
"\n"
"Please check the FielMedina Admin Validation panel to verify their proof of payment and approve the transaction."
